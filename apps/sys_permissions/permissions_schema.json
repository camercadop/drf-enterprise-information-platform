{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Permission Catalog",
  "description": "Defines permissions for an app's resources and their default role assignments. Merges with auto-generated CRUD defaults.",
  "type": "object",
  "required": ["resources"],
  "additionalProperties": false,
  "properties": {
    "access": {
      "oneOf": [
        { "const": false },
        {
          "type": "object",
          "required": ["label", "readonly", "default_roles"],
          "additionalProperties": false,
          "properties": {
            "label": {
              "type": "string",
              "minLength": 1
            },
            "readonly": {
              "type": "boolean"
            },
            "default_roles": {
              "type": "object",
              "required": ["owner", "admin", "member", "viewer"],
              "additionalProperties": false,
              "properties": {
                "owner": { "enum": [0, 1] },
                "admin": { "enum": [0, 1] },
                "member": { "enum": [0, 1] },
                "viewer": { "enum": [0, 1] }
              }
            }
          }
        }
      ]
    },
    "resources": {
      "oneOf": [
        { "const": false },
        {
          "type": "object",
          "minProperties": 1,
          "patternProperties": {
            "^[a-z][a-z0-9_]*$": {
              "oneOf": [
                { "const": false },
                {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "label": {
                      "type": "string",
                      "minLength": 1
                    },
                    "actions": {
                      "type": "object",
                      "patternProperties": {
                        "^[a-z][a-z0-9_]*$": {
                          "oneOf": [
                            { "const": false },
                            {
                              "type": "object",
                              "required": ["label", "readonly", "default_roles"],
                              "additionalProperties": false,
                              "properties": {
                                "label": {
                                  "type": "string",
                                  "minLength": 1
                                },
                                "readonly": {
                                  "type": "boolean"
                                },
                                "default_roles": {
                                  "type": "object",
                                  "required": ["owner", "admin", "member", "viewer"],
                                  "additionalProperties": false,
                                  "properties": {
                                    "owner": { "enum": [0, 1] },
                                    "admin": { "enum": [0, 1] },
                                    "member": { "enum": [0, 1] },
                                    "viewer": { "enum": [0, 1] }
                                  }
                                }
                              }
                            }
                          ]
                        }
                      },
                      "additionalProperties": false
                    }
                  }
                }
              ]
            }
          },
          "additionalProperties": false
        }
      ]
    }
  }
}
